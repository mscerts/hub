---
// Import necessary components and utilities
import MainLayout from "@/layouts/MainLayout.astro";
import AvatarBlogLarge from "@components/ui/avatars/AvatarBlogLarge.astro";
import CardBlog from "@components/ui/cards/CardBlog.astro";
import SocialShare from "@components/ui/buttons/SocialShare.astro";
import Giscus from "@components/ui/comments/Giscus.astro";
import { Image } from "astro:assets";
import { capitalize, formatDate } from "@utils/utils";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const blogPosts = await getCollection("blog", ({ data }) => {
    return data.draft !== true;
  });
  return blogPosts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

// Get the current post's data
const { post } = Astro.props;

// Render the MDX content
const { Content } = await render(post);

// Get all blog posts for related posts
const allBlogPosts: CollectionEntry<"blog">[] = await getCollection(
  "blog",
  ({ data }) => data.draft !== true,
);

// Get related posts based on tags (or just filter out current post)
const relatedPosts: CollectionEntry<"blog">[] = allBlogPosts
  .filter((blogEntry) => {
    // Exclude current post
    if (blogEntry.id === post.id) return false;

    // If the post has tags, try to match at least one tag
    if (post.data.tags && blogEntry.data.tags) {
      const hasMatchingTag = post.data.tags.some((tag) =>
        blogEntry.data.tags?.includes(tag),
      );
      return hasMatchingTag;
    }

    // Include posts without tags as potential related content
    return true;
  })
  .sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  )
  .slice(0, 4); // Limit to 4 related posts

const pageTitle: string = `${post.data.title} | ${SITE.title}`;
const metaDescription = post.data.description;
const ogTitle = `${post.data.title} | News | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": `${SITE.url}/news/${post.id}`,
    url: `${SITE.url}/news/${post.id}`,
    headline: post.data.title,
    description: post.data.description,
    image: post.data.cardImage?.src || `${SITE.url}/social.png`,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.updatedDate
      ? post.data.updatedDate.toISOString()
      : post.data.pubDate.toISOString(),
    author: post.data.authors.map(a => ({
      "@type": "Person",
      name: a.name,
      image: a.image?.src,
    })),
    publisher: {
      "@type": "Organization",
      name: SITE.title,
      logo: {
        "@type": "ImageObject",
        url: `${SITE.url}/favicon.ico`,
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${SITE.url}/news/${post.id}`,
    },
  }}
>
  <article class="mx-auto max-w-3xl px-4 pb-12 pt-6 sm:px-6 lg:px-8 lg:pt-10">
    <div class="max-w-2xl">
      {/* Author and metadata section */}
      <div class="mb-6 flex items-center justify-between">
        <div class="flex w-full gap-x-5 sm:items-center sm:gap-x-3">
          <AvatarBlogLarge blogEntry={post} />
          <div class="grow">
            <div class="flex items-center justify-between gap-x-2">
              <div>
                {/* Author name(s) */}
                <span class="font-bold text-neutral-700 dark:text-neutral-300">
                  {post.data.authors.map(a => a.name).join(" & ")}
                </span>
                {/* Post metadata */}
                <ul class="text-xs text-neutral-500">
                  <li
                    class="relative inline-block pe-6 before:absolute before:end-2 before:top-1/2 before:size-1 before:-translate-y-1/2 before:rounded-full before:bg-neutral-300 last:pe-0 last-of-type:before:hidden dark:text-neutral-400 dark:before:bg-neutral-600"
                  >
                    {formatDate(post.data.pubDate)}
                  </li>
                  {
                    post.data.updatedDate && (
                      <li class="relative inline-block pe-6 before:absolute before:end-2 before:top-1/2 before:size-1 before:-translate-y-1/2 before:rounded-full before:bg-neutral-300 last:pe-0 last-of-type:before:hidden dark:text-neutral-400 dark:before:bg-neutral-600">
                        Updated: {formatDate(post.data.updatedDate)}
                      </li>
                    )
                  }
                  <li
                    class="relative inline-block pe-6 before:absolute before:end-2 before:top-1/2 before:size-1 before:-translate-y-1/2 before:rounded-full before:bg-neutral-300 last:pe-0 last-of-type:before:hidden dark:text-neutral-400 dark:before:bg-neutral-600"
                  >
                    {post.data.readTime} min read
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Blog post title */}
      <h1
        class="mb-3 text-2xl font-bold text-neutral-800 md:text-3xl lg:text-4xl dark:text-neutral-200"
      >
        {post.data.title}
      </h1>

      {/* Cover image */}
      {
        post.data.cardImage && (
          <Image
            class="mb-6 w-full rounded-xl object-cover"
            src={post.data.cardImage}
            alt={post.data.title}
            draggable={false}
            format="avif"
            loading="eager"
          />
        )
      }

      {/* Blog post content - MDX */}
      <div
        class="prose prose-lg prose-neutral max-w-none dark:prose-invert"
      >
        <Content />
      </div>

      {/* Tags and share section */}
      <div
        class="mx-auto mt-8 grid max-w-(--breakpoint-lg) gap-y-5 border-t border-neutral-200 pt-8 sm:flex sm:items-center sm:justify-between sm:gap-y-0 dark:border-neutral-700"
      >
        {/* Blog post tags */}
        <div
          class="flex flex-wrap gap-x-2 gap-y-1 sm:flex-nowrap sm:items-center sm:gap-y-0"
        >
          {
            post.data.tags?.map((tag: string) => (
              <a
                href={`/news/tag/${tag.toLowerCase()}/`}
                class="inline-flex items-center gap-x-1.5 rounded-lg bg-neutral-400/30 px-3 py-1.5 text-xs font-medium text-neutral-700 hover:bg-neutral-400/50 dark:bg-neutral-700/60 dark:text-neutral-300 dark:hover:bg-neutral-700/80 transition-colors"
              >
                {capitalize(tag)}
              </a>
            ))
          }
        </div>
        {/* Share button */}
        <div class="flex items-center justify-end gap-x-1.5">
          <div class="inline-flex">
            <SocialShare pageTitle={post.data.title} />
          </div>
        </div>
      </div>
    </div>

    {/* Comments section */}
    <Giscus />
  </article>

  {/* Related articles section */}
  {
    relatedPosts.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
        <div class="mb-10 max-w-2xl">
          <h2 class="text-balance text-2xl font-bold text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200">
            Related articles
          </h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          {relatedPosts.map((entry) => (
            <CardBlog blogEntry={entry} />
          ))}
        </div>
      </section>
    )
  }
</MainLayout>
