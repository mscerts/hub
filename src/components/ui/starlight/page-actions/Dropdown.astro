---
import { Icon } from "@astrojs/starlight/components";
import Button from "./Button.astro";

interface Props {
  label: string;
  options: {
    label: string;
    href: string;
  }[];
  id?: "0" | "1";
}

const { label, options, id } = Astro.props;
---

<starlight-page-action-dropdown class="dropdown">
  <Button class="dropdown-toggle">
    <span>{label}</span>
    <Icon name="down-caret" size="1rem" />
  </Button>

  <div class="dropdown-menu">
    {
      options.map((option) => {
        return (
          <a href={option.href} class="dropdown-item" target="_blank">
            <span>{option.label}</span>
            <Icon name="external" size="1rem" class="external-icon" />
          </a>
        );
      })
    }
  </div>
</starlight-page-action-dropdown>

<style>
  .dropdown {
    position: relative;
    display: inline-block;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: auto;
    background-color: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.25rem;
    padding: 0.25rem;
    min-width: 201px;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.3),
      0 2px 4px -1px rgba(0, 0, 0, 0.2);
    display: none;
    z-index: 10;
  }

  .dropdown-menu.show {
    display: block;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    color: var(--sl-color-white);
    text-decoration: none;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    transition: background-color 0.15s ease;
    cursor: pointer;
  }

  .dropdown-item:hover {
    background-color: var(--sl-color-gray-5);
  }

  .dropdown-item span {
    flex: 1;
  }

  .dropdown-item .external-icon {
    margin-left: auto;
  }

  @media (min-width: 425px) {
    .dropdown-menu {
      left: 0;
      right: auto;
    }
  }
</style>

<script>
  class StarlightPageActionDropdown extends HTMLElement {
    constructor() {
      super();
      const toggle = this.querySelector('.dropdown-toggle') as HTMLButtonElement;
      const menu = this.querySelector('.dropdown-menu') as HTMLElement;

      if (!toggle || !menu) return;

      toggle.addEventListener("click", (e) => {
        e.stopPropagation();
        
        // Close all other dropdowns
        document.querySelectorAll('starlight-page-action-dropdown .dropdown-menu').forEach((m) => {
          if (m !== menu) m.classList.remove("show");
        });

        // Toggle current dropdown
        menu.classList.toggle("show");
      });

      menu.addEventListener("click", (e) => {
        e.stopPropagation();
      });
    }
  }

  if (!customElements.get('starlight-page-action-dropdown')) {
    customElements.define('starlight-page-action-dropdown', StarlightPageActionDropdown);
    
    // Global listener for closing dropdowns when clicking outside
    document.addEventListener("click", () => {
      document.querySelectorAll('starlight-page-action-dropdown .dropdown-menu').forEach((m) => {
        m.classList.remove("show");
      });
    });
  }
</script>
