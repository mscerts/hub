---
import AvatarBlogLarge from "@components/ui/avatars/AvatarBlogLarge.astro";
import { Image } from "astro:assets";
import { formatDate } from "@utils/utils";
import type { CollectionEntry } from "astro:content";

const { blogEntry } = Astro.props;

interface Props {
  blogEntry: CollectionEntry<"blog">;
}
---

<div class="group relative overflow-hidden rounded-2xl">
  <!-- Cover image - full width widespan (clickable) -->
  <a
    href={`/news/${blogEntry.id}/`}
    data-astro-prefetch
    class="block relative w-full h-48 sm:h-56 md:h-64 lg:h-72 overflow-hidden rounded-t-2xl"
  >
    <Image
      class="absolute start-0 top-0 size-full object-cover transition duration-500 group-hover:scale-105"
      src={blogEntry.data.cardImage}
      alt={blogEntry.data.cardImageAlt ?? blogEntry.data.title}
      draggable={false}
      loading="eager"
      format="avif"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    
    <!-- Date badge at top-right -->
    <div class="absolute top-4 right-4 z-10">
      <div class="rounded-lg bg-neutral-900/70 backdrop-blur-sm px-3 py-1.5 text-sm font-medium text-neutral-50">
        {formatDate(blogEntry.data.pubDate)}
      </div>
    </div>
  </a>

  <!-- Content -->
  <div class="p-4 sm:p-6 bg-neutral-100 dark:bg-neutral-900 rounded-b-2xl">
    <div class="flex items-center gap-x-3 mb-4">
      <AvatarBlogLarge blogEntry={blogEntry} />
      <div>
        <h4 class="font-bold text-neutral-800 dark:text-neutral-200">
          {blogEntry.data.authors.map(a => a.name).join(" & ")}
        </h4>
        <p class="text-xs text-neutral-500 dark:text-neutral-400">
          {formatDate(blogEntry.data.pubDate)} · {blogEntry.data.readTime} min read
        </p>
      </div>
    </div>

    <a href={`/news/${blogEntry.id}/`} data-astro-prefetch>
      <h3
        class="text-xl font-bold text-neutral-800 hover:text-indigo-600 md:text-2xl lg:text-3xl dark:text-neutral-200 dark:hover:text-indigo-400 transition-colors"
      >
        {blogEntry.data.title}
      </h3>
    </a>
    <p
      class="mt-2 text-base text-pretty text-neutral-600 dark:text-neutral-400"
    >
      {blogEntry.data.description}
    </p>

    <!-- Tags (clickable) -->
    {
      blogEntry.data.tags && blogEntry.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {blogEntry.data.tags.slice(0, 3).map((tag: string) => (
            <a
              href={`/news/tag/${tag.toLowerCase()}/`}
              class="inline-flex items-center gap-x-1.5 rounded-lg bg-indigo-100 px-3 py-1.5 text-xs font-medium text-indigo-800 hover:bg-indigo-200 dark:bg-indigo-900/30 dark:text-indigo-300 dark:hover:bg-indigo-900/50 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }
  </div>
</div>
